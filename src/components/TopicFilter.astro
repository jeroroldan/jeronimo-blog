---
import { getThemeFromCode, themes, themeToSlug } from "../lib/themeMapping";

interface Props {
  allThemes: string[];
  allCodes: string[];
  currentTheme?: string;
}

const { allThemes, allCodes, currentTheme } = Astro.props;

const themesToDisplay = currentTheme ? [currentTheme] : allThemes;

// Group codes by theme
const groupedCodes = allThemes.reduce((acc, theme) => {
  acc[theme] = allCodes.filter(code => getThemeFromCode(code) === theme);
  return acc;
}, {} as Record<string, string[]>);

// Theme colors
const themeColors: Record<string, string> = {
  'Seducción': '#f43f5e',
  'Informática': '#0ea5e9',
  'Trading': '#10b981',
  'Negocios': '#f59e0b',
  'Superación Personal': '#8b5cf6'
};
---

<div class="topic-filter-container glass-card animate-fade-in">
  <div class="filter-header">
    <div class="title-section">
      <h3>Explorar contenido</h3>
      <p class="subtitle">Filtra por categorías y etiquetas específicas</p>
    </div>
    
    <div class="search-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="tag-search" placeholder="Buscar etiqueta (ej: React, Ventas...)" aria-label="Buscar etiqueta" />
    </div>
  </div>

  <div class="filter-controls">
    <div class="theme-tabs-wrapper">
      <div class="theme-tabs" id="theme-tabs">
        <button class="theme-tab active" data-theme="all">
          <span class="dot" style="--theme-color: var(--accent)"></span>
          Todos
        </button>
        {themesToDisplay.map((theme) => (
          <button class="theme-tab" data-theme={theme}>
            <span class="dot" style={`--theme-color: ${themeColors[theme] || 'var(--text-muted)'}`}></span>
            {theme}
          </button>
        ))}
      </div>
    </div>
    
    <button id="clear-filters" class="clear-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"></path></svg>
      Limpiar filtros
    </button>
  </div>

  <div class="chips-display" id="chips-display">
    {themesToDisplay.map((theme) => (
      <div class="theme-chips-group active" data-theme-group={theme}>
        {groupedCodes[theme]?.map((code) => (
          <button 
            class="code-chip" 
            data-filter-theme={theme} 
            data-filter-code={code}
          >
            {code.charAt(0).toUpperCase() + code.slice(1).replace(/-/g, ' ')}
          </button>
        ))}
      </div>
    ))}
    
    <div id="no-results-msg" class="no-results hidden">
      No se encontraron etiquetas que coincidan con tu búsqueda.
    </div>
  </div>
</div>

<style>
  .topic-filter-container {
    padding: 2.5rem;
    margin-bottom: 3rem;
  }

  .filter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .title-section h3 {
    margin-bottom: 0.25rem;
    font-size: 1.5rem;
    color: var(--text-primary);
  }

  .subtitle {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .search-wrapper {
    position: relative;
    flex: 1;
    max-width: 320px;
  }

  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  #tag-search {
    width: 100%;
    padding: 0.8rem 1rem 0.8rem 2.5rem;
    background: var(--bg-primary);
    border: 1px solid var(--glass-border);
    border-radius: var(--border-radius-md);
    color: var(--text-primary);
    font-size: 0.95rem;
    transition: all var(--transition-fast);
  }

  #tag-search:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }

  .filter-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--glass-border);
    padding-bottom: 1rem;
  }

  .theme-tabs-wrapper {
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    flex: 1;
  }

  .theme-tabs-wrapper::-webkit-scrollbar {
    display: none;
  }

  .theme-tabs {
    display: flex;
    gap: 0.5rem;
  }

  .theme-tab {
    padding: 0.6rem 1.25rem;
    border-radius: 50px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--transition-fast);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .theme-tab:hover {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .theme-tab.active {
    background: var(--accent);
    color: white;
    box-shadow: 0 4px 12px var(--accent-soft);
  }

  .theme-tab .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--theme-color);
  }

  .theme-tab.active .dot {
    background-color: white;
  }

  .clear-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .clear-btn:hover {
    color: var(--accent);
  }

  .chips-display {
    min-height: 80px;
  }

  .theme-chips-group {
    display: none;
    flex-wrap: wrap;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
  }

  .theme-chips-group.active {
    display: flex;
  }

  .code-chip {
    padding: 0.5rem 1.2rem;
    border-radius: var(--border-radius-sm);
    background: var(--bg-secondary);
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .code-chip:hover {
    background: var(--bg-primary);
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .code-chip.active {
    background: var(--accent-soft);
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 4px 12px var(--accent-soft);
  }

  .no-results {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 1024px) {
    .filter-header {
      flex-direction: column;
      align-items: stretch;
    }
    
    .search-wrapper {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .topic-filter-container {
      padding: 1.5rem;
    }
    
    .filter-controls {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    
    .clear-btn {
      padding-left: 0.5rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const postsList = document.querySelector("main .posts-list");
    const themeTabs = document.querySelectorAll(".theme-tab");
    const chipsGroups = document.querySelectorAll(".theme-chips-group");
    const filterButtons = document.querySelectorAll(".code-chip");
    const tagSearch = document.getElementById("tag-search") as HTMLInputElement;
    const clearBtn = document.getElementById("clear-filters");
    const postItems = postsList?.querySelectorAll(":scope > .post-item") ?? [];
    const noResultsMsg = document.getElementById("no-results-msg");

    console.log(`[TopicFilter] Inicializado. Encontrados ${postItems.length} posts y ${filterButtons.length} etiquetas.`);

    function getActiveTheme() {
      return document.querySelector(".theme-tab.active")?.getAttribute("data-theme") || "all";
    }

    function syncChipGroups(query: string) {
      const activeTheme = getActiveTheme();
      let foundAny = false;

      chipsGroups.forEach(group => {
        const groupTheme = group.getAttribute("data-theme-group");
        const themeMatches = activeTheme === "all" || groupTheme === activeTheme;
        
        // Filter chips inside group based on search query
        let visibleInGroup = 0;
        group.querySelectorAll(".code-chip").forEach(chip => {
          const text = chip.textContent?.toLowerCase() || "";
          const matchesQuery = text.includes(query.toLowerCase());
          (chip as HTMLElement).style.display = matchesQuery ? "inline-block" : "none";
          if (matchesQuery) visibleInGroup++;
        });

        const shouldShowGroup = themeMatches && (query === "" || visibleInGroup > 0);
        group.classList.toggle("active", shouldShowGroup);
        if (shouldShowGroup) foundAny = true;
      });

      if (!foundAny && query !== "") {
        noResultsMsg?.classList.remove("hidden");
      } else {
        noResultsMsg?.classList.add("hidden");
      }
    }

    // Category Switching Logic
    themeTabs.forEach(tab => {
      tab.addEventListener("click", () => {
        themeTabs.forEach(t => t.classList.remove("active"));
        tab.classList.add("active");
        
        // Reset current tag filter when switching themes for clarity
        updatePostDisplay("all");
        
        // Sync tags visibility
        syncChipGroups(tagSearch.value || "");
      });
    });

    // Tag Search Logic
    tagSearch?.addEventListener("input", (e) => {
      syncChipGroups((e.target as HTMLInputElement).value);
    });

    // Post Filtering Logic
    function updatePostDisplay(selectedCode: string) {
      console.log(`[TopicFilter] Filtrando por código: "${selectedCode}"`);
      
      // Update chip active states
      filterButtons.forEach(btn => {
        if (btn.getAttribute("data-filter-code") === selectedCode) {
          btn.classList.add("active");
        } else {
          btn.classList.remove("active");
        }
      });

      let shownCount = 0;
      let hiddenCount = 0;

      // Filter post items
      postItems.forEach(item => {
        const postCode = item.getAttribute("data-code");
        const shouldShow = selectedCode === "all" || postCode === selectedCode;
        
        const htmlItem = item as HTMLElement;
        if (shouldShow) {
          htmlItem.style.setProperty("display", "block", "important");
          htmlItem.classList.remove("hidden");
          htmlItem.style.opacity = "1";
          htmlItem.style.transform = "scale(1)";
          shownCount++;
        } else {
          htmlItem.style.setProperty("display", "none", "important");
          htmlItem.classList.add("hidden");
          htmlItem.style.opacity = "0";
          htmlItem.style.transform = "scale(0.95)";
          hiddenCount++;
        }
      });

      console.log(`[TopicFilter] Resultado: ${shownCount} visibles, ${hiddenCount} ocultos.`);
    }

    filterButtons.forEach(button => {
      button.addEventListener("click", () => {
        const code = button.getAttribute("data-filter-code") || "all";
        const isAlreadyActive = button.classList.contains("active");
        
        // If clicking active, clear. Otherwise set active.
        updatePostDisplay(isAlreadyActive ? "all" : code);
      });
    });

    clearBtn?.addEventListener("click", () => {
      tagSearch.value = "";
      updatePostDisplay("all");
      
      themeTabs.forEach(t => t.classList.remove("active"));
      document.querySelector('[data-theme="all"]')?.classList.add("active");
      syncChipGroups("");
    });

    // Initial sync
    syncChipGroups("");
  });
</script>
