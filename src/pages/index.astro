---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import DefaultImage from '../assets/blog-placeholder-1.jpg';

// Obtener los posts más recientes (máximo 3 para la home)
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.home-container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 4rem 1.5rem;
			}

			.hero {
				text-align: center;
				padding: 6rem 2rem;
				background: linear-gradient(135deg, var(--accent-dark) 0%, var(--accent) 50%, var(--accent-light) 100%);
				color: white;
				border-radius: var(--border-radius-lg);
				box-shadow: 0 20px 50px rgba(99, 102, 241, 0.3);
				position: relative;
				overflow: hidden;
				margin-bottom: 5rem;
			}

			.hero::before {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0; bottom: 0;
				background: radial-gradient(circle at top right, rgba(255,255,255,0.2), transparent 60%);
				pointer-events: none;
			}

			.hero h1 {
				font-size: 4.5rem;
				margin-bottom: 1.5rem;
				color: #ffffff;
				letter-spacing: -0.04em;
				line-height: 1.1;
			}

			.hero p {
				font-size: 1.5rem;
				margin-bottom: 3rem;
				color: rgba(255, 255, 255, 0.9);
				max-width: 700px;
				margin-left: auto;
				margin-right: auto;
			}

			.cta-group {
				display: flex;
				gap: 1.5rem;
				justify-content: center;
			}

			.cta-button {
				display: inline-block;
				padding: 1.25rem 3rem;
				background: white;
				color: var(--accent-dark);
				text-decoration: none;
				border-radius: 50px;
				font-weight: 700;
				font-size: 1.1rem;
				box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
				transition: all var(--transition-normal);
			}

			.cta-button:hover {
				transform: translateY(-4px);
				box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
				background: var(--bg-primary);
			}

			.section-title {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				margin-bottom: 3rem;
				border-bottom: 1px solid var(--glass-border);
				padding-bottom: 1rem;
			}

			.section-title h2 {
				margin: 0;
				font-size: 2.5rem;
			}

			.view-all {
				font-weight: 600;
				color: var(--accent);
				text-decoration: none;
			}

			.posts-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2.5rem;
			}

			.post-card {
				display: flex;
				flex-direction: column;
				text-decoration: none;
				background: var(--bg-secondary);
				border: 1px solid var(--glass-border);
				border-radius: var(--border-radius-lg);
				overflow: hidden;
				transition: all var(--transition-normal);
				box-shadow: var(--glass-shadow);
			}

			.post-card:hover {
				transform: translateY(-8px);
				border-color: var(--accent);
				box-shadow: 0 20px 40px rgba(99, 102, 241, 0.15);
			}

			.image-wrapper {
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
			}

			.post-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.6s ease;
			}

			.post-card:hover .post-image {
				transform: scale(1.05);
			}

			.post-content {
				padding: 2rem;
				display: flex;
				flex-direction: column;
				flex: 1;
			}

			.post-title {
				font-size: 1.5rem;
				margin-bottom: 1rem;
				font-weight: 700;
				line-height: 1.3;
				color: var(--text-primary);
			}

			@media (max-width: 1024px) {
				.posts-grid { grid-template-columns: repeat(2, 1fr); }
				.hero h1 { font-size: 3.5rem; }
			}

			@media (max-width: 768px) {
				.posts-grid { grid-template-columns: 1fr; }
				.hero { padding: 4rem 1.5rem; }
				.hero h1 { font-size: 2.5rem; }
				.cta-group { flex-direction: column; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="home-container">
			<section class="hero animate-fade-in">
				<h1>Bienvenido a {SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
				<div class="cta-group">
					<a href="/blog" class="cta-button">Explorar Blog</a>
				</div>
			</section>

			<section class="recent-posts">
				<div class="section-title">
					<h2>Posts Recientes</h2>
					<a href="/blog" class="view-all">Ver todo →</a>
				</div>
				<div class="posts-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							<div class="image-wrapper">
								<Image
									src={post.data.heroImage && typeof post.data.heroImage === 'object' ? post.data.heroImage : DefaultImage}
									alt={post.data.title}
									class="post-image"
									width={400}
									height={225}
								/>
							</div>
							<div class="post-content">
								<h3 class="post-title">{post.data.title}</h3>
								<div class="meta" style="margin-top: auto; color: var(--text-muted); font-size: 0.9rem;">
									<FormattedDate date={post.data.pubDate} />
								</div>
							</div>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

