---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import SearchBox from "../../components/SearchBox.astro";
import TopicFilter from "../../components/TopicFilter.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import DefaultImage from "../../assets/blog-placeholder-1.jpg";
import { getThemeFromCode, themes, themeToSlug, slugToTheme } from "../../lib/themeMapping";

export const getStaticPaths = (async () => {
  const slugs = ['seduccion', 'informatica', 'trading', 'negocios', 'superacion'];
  console.log("HARDCODED generating paths for:", slugs);
  return slugs.map(s => ({ params: { theme: s }, props: {} }));
}) satisfies GetStaticPaths;

const { theme: themeSlug } = Astro.params;
const originalTheme = slugToTheme[themeSlug] || "Informática";

// Get all posts for this theme
const allPosts = await getCollection("blog");
const posts = allPosts
  .filter(post => {
    const postTheme = getThemeFromCode(post.data.code);
    return postTheme === originalTheme;
  })
  .sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

// Get unique codes for this theme for filtering
const themeCodes = [
  ...new Set(
    posts
      .map(post => post.data.code)
      .filter(Boolean)
  )
].sort();

// Get theme description
const themeDescriptions: Record<string, string> = {
  seduccion: "Descubre el arte de la seducción, la atracción y las relaciones humanas.",
  informatica: "Explora el mundo de la tecnología, programación y desarrollo de software.",
  trading: "Aprende sobre inversiones, trading y gestión financiera profesional.",
  negocios: "Desarrolla habilidades empresariales, de liderazgo y emprendimiento.",
  superacion: "Crece personalmente con técnicas de superación, aprendizaje y productividad."
};

const themeDescription = themeDescriptions[themeSlug.toLowerCase()] || "Explora nuestro contenido especializado.";
const themeTitle = originalTheme;

---
<!doctype html>
<html lang="es">
  <head>
    <BaseHead 
      title={`${themeTitle} | ${SITE_TITLE}`} 
      description={themeDescription} 
    />
    <style>
      :root {
        --theme-primary: var(--accent); /* Will be overridden per theme */
      }
      
      /* Theme-specific colors - these will be set via inline style or JS */
      main {
        width: 960px;
      }
      
      ul {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      
      ul li {
        width: calc(50% - 1rem);
      }
      
      ul li * {
        text-decoration: none;
        transition: 0.2s ease;
      }
      
      ul li:first-child {
        width: 100%;
        margin-bottom: 1rem;
        text-align: center;
      }
      
      ul li:first-child img {
        width: 100%;
      }
      
      ul li:first-child .title {
        font-size: 2.369rem;
      }
      
      ul li img {
        margin-bottom: 0.5rem;
        border-radius: 12px;
      }
      
      ul li a {
        display: block;
      }
      
      .title {
        margin: 0;
        color: rgb(var(--black));
        line-height: 1;
      }
      
      .date {
        margin: 0;
        color: rgb(var(--gray));
      }
      
      ul li a:hover h4,
      ul li a:hover .date {
        color: rgb(var(--accent));
      }
      
      ul a:hover img {
        box-shadow: var(--box-shadow);
      }
      
      @media (max-width: 720px) {
        ul {
          gap: 0.5em;
        }
        
        ul li {
          width: 100%;
          text-align: center;
        }
        
        ul li:first-child {
          margin-bottom: 0;
        }
        
        ul li:first-child .title {
          font-size: 1.563em;
        }
      }
      
      .post-item {
        transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }

      
      .post-item.hidden {
        display: none;
      }
      
      /* Estilos para paginación */
      .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        margin-top: 3rem;
        padding: 2rem 0;
      }
      
      .pagination a,
      .pagination span {
        padding: 0.5rem 1rem;
        border: 2px solid rgb(var(--accent));
        border-radius: 8px;
        text-decoration: none;
        color: rgb(var(--accent));
        transition: all 0.2s ease;
        font-weight: 500;
      }
      
      .pagination a:hover {
        background: rgb(var(--accent));
        color: white;
      }
      
      .pagination .current {
        background: rgb(var(--accent));
        color: white;
      }
      
      .pagination .disabled {
        opacity: 0.3;
        cursor: not-allowed;
        pointer-events: none;
      }
      
      /* Theme-specific styling will be applied via inline style */
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1
        style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0;"
      >
        Blog de {SITE_TITLE}
      </h1>
      <section>
        <div class="theme-header" style="text-align: center; margin-bottom: 2rem;">
          <h1 style="color: var(--theme-primary); margin-bottom: 0.5rem;">
            {themeTitle}
          </h1>
          <p style="color: rgb(var(--gray)); font-size: 1.1rem; max-width: 600px; margin: 0 auto;">
            {themeDescription}
          </p>
        </div>
        
        <!-- Componente de búsqueda -->
        <SearchBox />
        
        <TopicFilter allThemes={themes} allCodes={themeCodes} currentTheme={originalTheme} />
        
        <ul>
          {
            posts.map((post) => (
              <li
                class="post-item"
                data-code={post.data.code || "sin-codigo"}
              >
                <a href={`/blog/${post.id}/`}>
                  <Image
                    width={720}
                    height={360}
                    src={
                      post.data.heroImage &&
                      typeof post.data.heroImage ===
                        "object"
                        ? post.data.heroImage
                        : DefaultImage
                    }
                    alt={post.data.title}
                  />
                  <h2 class="title">{post.data.title}</h2>
                  <p class="date">
                    <FormattedDate
                      date={post.data.pubDate}
                    />
                  </p>
                </a>
              </li>
            ))
          }
        </ul>
        
        <!-- Controles de paginación -->
        <nav class="pagination" aria-label="Navegación de páginas">
          {
            /* Pagination logic would need to be implemented - for now showing placeholder */
            <span class="current">Página 1 de 1</span>
          }
        </nav>
      </section>
    </main>
    <Footer />
    
    <script define:vars={{ themeSlug }}>
      // Set theme-specific CSS variable
      document.addEventListener("DOMContentLoaded", function () {
        const themeColors = {
          seduccion: "#E91E63",
          informatica: "#2196F3",
          trading: "#4CAF50",
          negocios: "#FF9800",
          superacion: "#9C27B0"
        };
        
        const themeLower = themeSlug.toLowerCase();
        const themeColor = themeColors[themeLower] || "#2196F3";
        
        // Set CSS variable for theme primary color
        document.documentElement.style.setProperty('--theme-primary', themeColor);
        
        // Also set accent color for consistency
        document.documentElement.style.setProperty('--accent', themeColor);
      });
    </script>
  </body>
</html>