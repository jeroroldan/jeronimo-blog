---
import { Image } from "astro:assets";
import { getCollection, type CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import TopicFilter from "../../components/TopicFilter.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import DefaultImage from "../../assets/blog-placeholder-1.jpg";
import { getThemeFromCode } from "../../lib/themeMapping";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("blog");
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  // Get unique themes and codes
  const allThemes = [
    ...new Set(allPosts.map((post) => getThemeFromCode(post.data.code))),
  ].sort();
  const allCodes = [
    ...new Set(
      allPosts.map((post) => post.data.code).filter((c): c is string => !!c),
    ),
  ].sort();

  return paginate(sortedPosts, {
    pageSize: 13, // 1 featured + 12 grid
    props: { allThemes, allCodes },
  });
}) satisfies GetStaticPaths;

const { page, allThemes = [], allCodes = [] } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`${SITE_TITLE} | Blog`} description={SITE_DESCRIPTION} />
    <style>
      .blog-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 1.5rem; /* Asegura espacio superior */
      }

      .posts-list {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
        list-style-type: none;
        margin: 4rem 0; /* Más espacio entre el filtro y la lista */
        padding: 0;
      }

      .post-item {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .post-item.featured {
        grid-column: 1 / -1;
        margin-bottom: 2rem;
      }

      .post-item.hidden {
        display: none;
      }

      .post-card {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        height: 100%;
        background: var(--bg-secondary);
        border: 1px solid var(--glass-border);
        border-radius: var(--border-radius-lg);
        overflow: hidden;
        transition: all var(--transition-normal);
        box-shadow: var(--glass-shadow);
      }

      .post-item.featured .post-card {
        flex-direction: row; /* Layout horizontal para destacado */
        min-height: 450px;
        height: auto;
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
      }

      .post-card:hover {
        transform: translateY(-8px);
        border-color: var(--accent);
        box-shadow: 0 20px 40px rgba(99, 102, 241, 0.15);
      }

      .image-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
      }

      .post-item.featured .image-wrapper {
        width: 55%;
        height: auto;
        min-height: 450px;
        aspect-ratio: auto;
      }

      .post-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }

      .post-card:hover .post-image {
        transform: scale(1.05);
      }

      .content-wrapper {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
      }

      .post-item.featured .content-wrapper {
        padding: 3rem;
        width: 45%;
      }

      .category-tag {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.75rem;
        letter-spacing: 0.05em;
      }

      .title {
        margin: 0 0 0.75rem 0;
        font-size: 1.5rem;
        line-height: 1.3;
        color: var(--text-primary);
        font-weight: 700;
      }

      .post-item.featured .title {
        font-size: 2.75rem;
        margin-bottom: 1.5rem;
      }

      .description {
        font-size: 1rem;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .post-item:not(.featured) .description {
        display: none;
      }

      .meta {
        margin-top: auto;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.875rem;
        color: var(--text-muted);
      }

      /* Pagination */
      .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        margin: 4rem 0;
      }

      .page-btn {
        padding: 0.75rem 1.5rem;
        border-radius: var(--border-radius-md);
        background: var(--bg-secondary);
        border: 1px solid var(--glass-border);
        color: var(--text-primary);
        font-weight: 600;
        text-decoration: none;
        transition: all var(--transition-fast);
      }

      .page-btn:hover:not(.disabled) {
        border-color: var(--accent);
        color: var(--accent);
        transform: translateY(-2px);
      }

      .page-btn.active {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
      }

      .page-btn.disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }

      @media (max-width: 1024px) {
        .posts-list {
          grid-template-columns: repeat(2, 1fr);
        }
        .post-item.featured {
          flex-direction: column;
          height: auto;
        }
        .post-item.featured .image-wrapper,
        .post-item.featured .content-wrapper {
          width: 100%;
        }
        .post-item.featured .post-card {
          flex-direction: column;
          height: auto;
        }
      }

      @media (max-width: 768px) {
        .posts-list {
          grid-template-columns: 1fr;
        }
        .post-item.featured .title {
          font-size: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="blog-container">
      <section class="animate-fade-in">
        <TopicFilter allThemes={allThemes} allCodes={allCodes} />

        <ul class="posts-list">
          {
            page.data.map((post, index) => {
              const isFeatured = index === 0 && page.currentPage === 1;
              return (
                <li
                  class={`post-item ${isFeatured ? "featured" : ""}`}
                  data-code={post.data.code || "sin-codigo"}
                  data-theme={getThemeFromCode(post.data.code)}
                >
                  <a href={`/blog/${post.id}/`} class="post-card">
                    <div class="image-wrapper">
                      <Image
                        width={isFeatured ? 1024 : 720}
                        height={isFeatured ? 512 : 400}
                        src={
                          post.data.heroImage &&
                          typeof post.data.heroImage === "object"
                            ? post.data.heroImage
                            : DefaultImage
                        }
                        alt={post.data.title}
                        class="post-image"
                      />
                    </div>
                    <div class="content-wrapper">
                      <span class="category-tag">{getThemeFromCode(post.data.code)}</span>
                      <h2 class="title">{post.data.title}</h2>
                      {isFeatured && <p class="description">{post.data.description}</p>}
                      <div class="meta">
                        <FormattedDate date={post.data.pubDate} />
                        <span>•</span>
                        <span>Lectura rápida</span>
                      </div>
                    </div>
                  </a>
                </li>
              );
            })
          }
        </ul>

        <nav class="pagination" aria-label="Paginación">
          <a 
            href={page.url.prev} 
            class={`page-btn ${!page.url.prev ? "disabled" : ""}`}
          >
            ← Anterior
          </a>
          
          <span class="page-btn active">
            {page.currentPage} / {page.lastPage}
          </span>

          <a 
            href={page.url.next} 
            class={`page-btn ${!page.url.next ? "disabled" : ""}`}
          >
            Siguiente →
          </a>
        </nav>
      </section>
    </main>
    <Footer />
  </body>
</html>

